UNRAID_URL=https://tower.local/graphql
UNRAID_API_KEY=replace-with-a-least-privilege-api-key

# stdio is ideal for local desktop clients; http is ideal for Docker deployment.
MCP_TRANSPORT=http
MCP_HTTP_BEARER_TOKEN=replace-with-a-random-token-at-least-16-chars
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=3000
MCP_HTTP_PATH=/mcp
MCP_HTTP_MAX_SESSIONS=50
MCP_HTTP_SESSION_IDLE_TIMEOUT_MS=900000

# Comma-separated list of hostnames allowed in the Host header (DNS rebinding protection).
# Required when MCP_HTTP_HOST=0.0.0.0 and the server is accessed via a hostname other than localhost.
# Example: MCP_HTTP_ALLOWED_HOSTS=localhost,myhost.local,192.168.1.100
# MCP_HTTP_ALLOWED_HOSTS=

# Deprecated compatibility setting. Tools are registered up front for reliable discovery.
UNRAID_DEFAULT_TOOLSETS=health

# Set true only for lab systems with self-signed certificates you explicitly trust.
UNRAID_ALLOW_INSECURE_TLS=false
UNRAID_REQUEST_TIMEOUT_MS=10000
UNRAID_SCHEMA_CACHE_TTL_MS=300000
UNRAID_MAX_CONCURRENCY=4
UNRAID_RATE_LIMIT_PER_10S=90
UNRAID_MAX_RESPONSE_BYTES=1000000
UNRAID_ENABLE_MUTATIONS=false
UNRAID_PLUGIN_HOST_ALLOWLIST=raw.githubusercontent.com,github.com

# Disabled by default because it gives callers arbitrary API reach.
UNRAID_ENABLE_RAW_GRAPHQL=false
